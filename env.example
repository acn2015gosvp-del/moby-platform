# ============================================
# MOBY Platform 환경 변수 설정
# ============================================
# 
# 사용 방법:
# 1. 이 파일을 .env로 복사하세요
#    Windows: copy env.example .env
#    Linux/Mac: cp env.example .env
# 2. 아래 값들을 실제 값으로 변경하세요
# 3. .env 파일은 Git에 커밋되지 않습니다 (보안)
# ============================================

# -------------------------------------------------------------------
# MQTT 설정
# -------------------------------------------------------------------
MQTT_HOST=localhost
MQTT_PORT=1883

# -------------------------------------------------------------------
# InfluxDB 설정
# -------------------------------------------------------------------
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influxdb-token-here
INFLUX_ORG=your-influxdb-org-here

# -------------------------------------------------------------------
# OpenAI API 설정 (LLM 기능 사용 시)
# -------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here

# -------------------------------------------------------------------
# 기타 설정 (선택사항)
# -------------------------------------------------------------------
# DEBUG=true
# LOG_LEVEL=INFO

